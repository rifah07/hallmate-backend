generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS

enum UserRole {
  SUPER_ADMIN
  PROVOST
  HOUSE_TUTOR
  ASSISTANT_WARDEN
  OFFICE_STAFF
  DINING_STAFF
  MAINTENANCE_STAFF
  GUARD
  STUDENT
  PARENT
}

enum AccountStatus {
  ACTIVE
  LOCKED
  SUSPENDED
  SEAT_CANCELLED
  INACTIVE
  GRADUATED
}

enum Program {
  UNDERGRADUATE
  MASTERS
  PHD
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
}

enum RoomType {
  SINGLE
  DOUBLE
  TRIPLE
  FOUR_SHARING
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  PARTIALLY_OCCUPIED
  MAINTENANCE
  RESERVED
}

enum Wing {
  A
  B
}

enum ApplicationType {
  SEAT_APPLICATION
  SEAT_CANCELLATION
  SEAT_TRANSFER
  SEAT_SWAP
  LEAVE
  COMPLAINT
  MAINTENANCE
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  SHORT_LEAVE
  LONG_LEAVE
  OVERNIGHT
  MEDICAL
  EMERGENCY
}

enum ComplaintCategory {
  ELECTRICAL
  PLUMBING
  FURNITURE
  CLEANLINESS
  MESS_FOOD
  NOISE
  SECURITY
  HARASSMENT
  OTHER
}

enum ComplaintPriority {
  LOW
  NORMAL
  URGENT
  EMERGENCY
}

enum ComplaintStatus {
  SUBMITTED
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum BillType {
  RENT
  MESS
  ELECTRICITY
  FINE
  CAUTION_MONEY
  OTHER
}

enum BillStatus {
  UNPAID
  PROCESSING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentGateway {
  BKASH
  NAGAD
  BANK_TRANSFER
  CASH
  SSLCOMMERZ
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// MAIN MODELS

// ─────────────────────────────────────────────
// (public module)
// ─────────────────────────────────────────────

enum NoticePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum PublicApplicationType {
  SEAT_REQUEST
  INFORMATION_REQUEST
  GENERAL_INQUIRY
  ADMISSION_QUERY
}

enum GalleryCategory {
  INFRASTRUCTURE
  EVENTS
  SPORTS
  CULTURAL
  ACADEMICS
  DINING
  GENERAL
}

enum FacilityCategory {
  ACCOMMODATION
  DINING
  SPORTS
  ACADEMIC
  HEALTH
  RECREATION
  UTILITIES
}

enum StaffCategory {
  ADMINISTRATIVE
  ACADEMIC
  SUPPORT
  SECURITY
  DINING
  MAINTENANCE
}

model RefreshToken {
  id     String @id @default(uuid())
  token  String @unique // store hashed token
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  isRevoked Boolean   @default(false)
  revokedAt DateTime?

  // Device/session info (useful for "logout all devices")
  userAgent String?
  ipAddress String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model User {
  id           String   @id @default(uuid())
  universityId String   @unique
  role         UserRole

  // Basic Info
  name  String
  email String  @unique
  phone String
  photo String?

  // Authentication
  password             String
  accountStatus        AccountStatus @default(ACTIVE)
  failedLoginAttempts  Int           @default(0)
  isFirstLogin         Boolean       @default(true)
  oneTimePassword      String?
  otpExpiresAt         DateTime?
  passwordChangedAt    DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?

  // Authorization
  refreshTokens RefreshToken[]

  // Seat Cancellation Info
  cancellationReason String?
  cancelledBy        String? // userId who cancelled
  cancelledAt        DateTime?

  // Student-specific fields
  department        String?
  year              Int?
  program           Program?
  session           String?
  bloodGroup        BloodGroup?
  nationalId        String?
  studentPhoto      String?
  medicalConditions String?
  allergies         String?

  // Room assignment
  currentRoomId String?
  currentRoom   Room?          @relation("CurrentResidents", fields: [currentRoomId], references: [id])
  roomOccupants RoomOccupant[]

  // Provost-specific
  provostMessage String?   @db.Text
  tenureStart    DateTime?
  tenureEnd      DateTime?

  // House Tutor-specific
  assignedFloor Int?

  // Staff-specific
  designation String?
  joiningDate DateTime?

  // Relations
  emergencyContacts EmergencyContact[]
  guardianInfo      GuardianInfo?
  applications      Application[]
  complaints        Complaint[]
  bills             Bill[]
  payments          Payment[]
  mealLogs          MealLog[]
  mealCancellations MealCancellation[] @relation("MealCancellations")
  gateEntries       GateEntry[]
  visitors          Visitor[]
  notifications     Notification[]
  seatAllocations   SeatAllocation[]
  provostHistories  ProvostHistory[]  @relation("ProvostHistoryUser")

  // Audit
  createdBy String?
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([email])
  @@index([universityId])
  @@index([role, accountStatus])
  @@index([currentRoomId])
  @@index([assignedFloor])
}

model EmergencyContact {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name     String
  phone    String
  relation String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model GuardianInfo {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name     String
  phone    String
  relation String
  address  String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoomOccupant {
  id           String   @id @default(uuid())
  roomId       String
  userId       String
  bedNumber    Int // 1-4
  assignedDate DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roomId, bedNumber])
  @@index([roomId])
  @@index([userId])
  @@map("room_occupants")
}

model Room {
  id               String     @id @default(uuid())
  roomNumber       String     @unique
  floor            Int
  wing             Wing
  roomType         RoomType
  capacity         Int
  currentOccupancy Int        @default(0)
  status           RoomStatus @default(AVAILABLE)

  occupants RoomOccupant[]

  hasAC           Boolean @default(false)
  hasBalcony      Boolean @default(false)
  hasAttachedBath Boolean @default(false)

  // Furniture inventory (JSON)
  furnitureInventory Json?

  // Relations
  currentResidents User[]           @relation("CurrentResidents")
  seatAllocations  SeatAllocation[]
  complaints       Complaint[]

  // Audit
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([floor, wing])
  @@index([status])
  @@index([roomType])
}

model SeatAllocation {
  id        String @id @default(uuid())
  studentId String
  student   User   @relation(fields: [studentId], references: [id])
  roomId    String
  room      Room   @relation(fields: [roomId], references: [id])

  allocatedAt DateTime  @default(now())
  vacatedAt   DateTime?
  isActive    Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([roomId])
  @@index([isActive])
}

model Application {
  id     String            @id @default(uuid())
  type   ApplicationType
  status ApplicationStatus @default(PENDING)

  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  // Application data (JSON - flexible for different types)
  data Json

  // File attachments
  attachments String[]

  // Assignment
  assignedTo     String?
  assignedToRole UserRole?

  // Response
  responseNote String?   @db.Text
  respondedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([type, status])
  @@index([assignedTo])
}

model Complaint {
  id       String            @id @default(uuid())
  category ComplaintCategory
  priority ComplaintPriority @default(NORMAL)
  status   ComplaintStatus   @default(SUBMITTED)

  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  roomId String?
  room   Room?   @relation(fields: [roomId], references: [id])

  title       String
  description String   @db.Text
  attachments String[]

  // Assignment
  assignedTo String?
  assignedAt DateTime?

  // Resolution
  resolutionNote String?   @db.Text
  resolvedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([status, priority])
  @@index([assignedTo])
}

model Bill {
  id     String     @id @default(uuid())
  type   BillType
  status BillStatus @default(UNPAID)

  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  amount  Float
  month   Int
  year    Int
  dueDate DateTime
  paidAt  DateTime?

  // Fine calculation
  lateFee Float @default(0)

  // Relations
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, type, month, year])
  @@index([studentId])
  @@index([status])
  @@index([dueDate])
}

model Payment {
  id     String @id @default(uuid())
  billId String
  bill   Bill   @relation(fields: [billId], references: [id])

  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  amount  Float
  gateway PaymentGateway
  status  PaymentStatus  @default(PENDING)

  transactionId   String? @unique
  gatewayResponse Json?

  paidAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([billId])
  @@index([studentId])
  @@index([status])
  @@index([transactionId])
}

model Notice {
  id      String @id @default(uuid())
  title   String
  content String @db.Text

  // Attachments
  pdfUrl   String?
  imageUrl String?

  // Targeting
  targetAudience String // ALL, FLOOR_SPECIFIC, YEAR_SPECIFIC, PROGRAM_SPECIFIC
  targetValue    String?

  priority String @default("NORMAL")
  category String @default("GENERAL")

  isPublic  Boolean   @default(false)
  isActive  Boolean   @default(true)
  expiresAt DateTime?

  createdBy     String
  createdByRole UserRole
  views         Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, isPublic])
  @@index([createdAt])
}

model MealLog {
  id        String @id @default(uuid())
  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  date      DateTime @db.Date
  breakfast Boolean  @default(false)
  lunch     Boolean  @default(false)
  dinner    Boolean  @default(false)

  createdAt DateTime @default(now())

  @@unique([studentId, date])
  @@index([studentId])
  @@index([date])
}

model MealCancellation {
  id          String   @id @default(uuid())
  studentId   String
  student     User     @relation("MealCancellations", fields: [studentId], references: [id], onDelete: Cascade)
  
  date        DateTime @db.Date
  
  // Which meals are cancelled for this date
  breakfast   Boolean  @default(false)
  lunch       Boolean  @default(false)
  dinner      Boolean  @default(false)
  
  // Metadata
  reason      String?
  cancelledAt DateTime @default(now())
  
  // Indexes for fast queries
  @@unique([studentId, date])
  @@index([studentId])
  @@index([date])
  @@map("meal_cancellations")
}

model MealSettings {
  id                        String  @id @default(uuid())
  cancellationDeadlineHours Int     @default(24)
  allowPastCancellation     Boolean @default(false)
  requireReason             Boolean @default(false)
  maxCancellationDays       Int     @default(30)
  
  updatedAt                 DateTime @updatedAt
  
  @@map("meal_settings")
}

model GateEntry {
  id        String @id @default(uuid())
  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  entryTime    DateTime?
  exitTime     DateTime?
  isLateReturn Boolean   @default(false)

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([createdAt])
}

model Visitor {
  id        String  @id @default(uuid())
  name      String
  nidNumber String
  phone     String
  relation  String
  purpose   String
  photo     String?

  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  approved   Boolean   @default(false)
  approvedAt DateTime?

  entryTime DateTime
  exitTime  DateTime?

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([entryTime])
}

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type    String
  title   String
  message String @db.Text

  relatedEntityType String?
  relatedEntityId   String?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

// AUDIT LOG

model AuditLog {
  id        String  @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  changes   Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// public models
// ─────────────────────────────────────────────

model HallInfo {
  id          String  @id @default(uuid())
  name        String
  established Int
  location    String
  description String  @db.Text
  vision      String? @db.Text
  mission     String? @db.Text
  capacity    Int
  totalRooms  Int
  logoUrl     String?
  coverUrl    String?
  mapEmbedUrl String?
  email       String?
  phone       String?
  address     String? @db.Text
  socialLinks Json? // { facebook, website, etc. }

  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PublicPageContent {
  id      String @id @default(uuid())
  page    String @unique // "about", "admission", "dining_overview"
  content Json   // flexible structured content
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([page])
}

model Facility {
  id          String           @id @default(uuid())
  name        String
  slug        String           @unique
  category    FacilityCategory
  description String           @db.Text
  iconUrl     String?
  imageUrl    String?
  isActive    Boolean          @default(true)
  sortOrder   Int              @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([slug])
}

model FAQ {
  id       String  @id @default(uuid())
  question String
  answer   String  @db.Text
  category String  @default("GENERAL")
  isActive Boolean @default(true)
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, isActive])
}

model GalleryItem {
  id          String          @id @default(uuid())
  title       String
  description String?
  imageUrl    String
  thumbnailUrl String?
  category    GalleryCategory @default(GENERAL)
  tags        String[]
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)
  capturedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, isActive])
}

model PublicNotice {
  id      String        @id @default(uuid())
  title   String
  slug    String        @unique
  content String        @db.Text
  summary String?

  pdfUrl   String?
  imageUrl String?

  priority    NoticePriority @default(NORMAL)
  category    String         @default("GENERAL")
  tags        String[]

  isPublished Boolean   @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?
  views       Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isPublished, expiresAt])
  @@index([category])
  @@index([createdAt])
}

model PublicEvent {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String   @db.Text
  summary     String?
  venue       String?
  imageUrl    String?

  startDate DateTime
  endDate   DateTime?
  isAllDay  Boolean   @default(false)

  tags        String[]
  isPublished Boolean  @default(false)
  isFeatured  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isPublished, startDate])
  @@index([isFeatured])
}

model Achievement {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  category    String   @default("GENERAL")
  imageUrl    String?
  year        Int
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([year, isActive])
  @@index([category])
}

model StaffProfile {
  id          String        @id @default(uuid())
  name        String
  designation String
  category    StaffCategory
  department  String?
  email       String?
  phone       String?
  photoUrl    String?
  bio         String?       @db.Text
  qualifications String?   @db.Text
  joiningDate DateTime?
  isPublic    Boolean       @default(true)
  sortOrder   Int           @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, isPublic])
}

model HouseTutorProfile {
  id          String   @id @default(uuid())
  name        String
  designation String   @default("House Tutor")
  department  String
  floor       Int?
  wing        String?
  email       String?
  phone       String?
  photoUrl    String?
  bio         String?  @db.Text
  officeHours String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([floor])
}

model DiningInfo {
  id           String  @id @default(uuid())
  mealPlan     Json    // { breakfast, lunch, dinner: { time, price, description } }
  weeklyMenu   Json?   // { monday: { breakfast, lunch, dinner }, ... }
  specialDiets String[]
  capacity     Int?
  location     String?
  imageUrl     String?
  contactPhone String?
  notice       String? @db.Text
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdmissionInfo {
  id               String   @id @default(uuid())
  session          String
  eligibility      String   @db.Text
  process          String   @db.Text
  requiredDocs     String[]
  importantDates   Json?    // { applicationStart, applicationEnd, resultDate }
  seatCapacity     Int?
  applicationFee   Float?
  contactEmail     String?
  contactPhone     String?
  faqItems         Json?
  isActive         Boolean  @default(true)
  isCurrent        Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isCurrent, isActive])
}

model ContactSubmission {
  id      String  @id @default(uuid())
  name    String
  email   String
  phone   String?
  subject String
  message String  @db.Text
  isRead  Boolean @default(false)
  repliedAt DateTime?

  ipAddress String?
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
}

model PublicApplication {
  id     String                @id @default(uuid())
  type   PublicApplicationType
  status ApplicationStatus     @default(PENDING)

  // Applicant info
  applicantName  String
  applicantEmail String
  applicantPhone String
  studentId      String?
  program        String?
  department     String?
  session        String?

  // Application data
  subject     String
  message     String  @db.Text
  attachments String[]

  // Response (safe to expose)
  responseNote String?   @db.Text
  respondedAt  DateTime?

  // Internal only (never expose)
  assignedTo String?
  internalNote String? @db.Text

  ipAddress String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([applicantEmail])
  @@index([createdAt])
}

model ProvostHistory {
  id            String  @id @default(uuid())
  name          String
  photoUrl      String? // Cloudinary secure_url
  photoPublicId String? // Cloudinary public_id — never exposed publicly

  designation String  @default("Provost")
  department  String?

  tenureStart DateTime
  tenureEnd   DateTime? // null = currently serving
  isCurrent   Boolean   @default(false)

  bio       String? @db.Text
  sortOrder Int     @default(0)

  // Link to User- used by self-edit guard so PROVOST cannot edit their own record
  userId String?
  user   User?   @relation("ProvostHistoryUser", fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isCurrent])
  @@index([tenureStart])
  @@index([userId])
}